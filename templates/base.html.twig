<!DOCTYPE html>
<html lang="fr">

	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>
			{% block title %}Compagnie des Archers des Albères
			{% endblock %}
		</title>
		<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🏹</text></svg>">

		{% block stylesheets %}
			<link rel="stylesheet" href="{{ asset('css/style.css') }}">
		{% endblock %}

		{% block javascripts %}
			{% block importmap %}
				{{ importmap('app') }}
			{% endblock %}
		{% endblock %}

		{% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
		{% if frankenphpHotReload %}
			<meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
			<script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
			<script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
		{% endif %}
	</head>

	<body>
		<div
			class="page-container">

			{# SIDEBAR - Commune à toutes les pages #}
			<aside class="sidebar">
				<div class="sidebar-logo">
					<div class="sidebar-logo-icon">
						<img src="{{ asset('images/logoarcherie-transparent.png') }}" alt="Logo Archers">
					</div>
					<div class="sidebar-logo-text">Archers des Albères</div>
				</div>

				<nav class="sidebar-nav">
					<a href="{{ path('app_home') }}" class="sidebar-link {{ app.request.attributes.get('_route') == 'app_home' ? 'active' : '' }}">Accueil</a>
					<a href="{{ path('app_actualites') }}" class="sidebar-link {{ app.request.attributes.get('_route') == 'app_actualites' ? 'active' : '' }}">Actualités</a>
					<a href="{{ path('app_adhesion') }}" class="sidebar-link {{ app.request.attributes.get('_route') == 'app_adhesion' ? 'active' : '' }}">Adhésion</a>
					<a href="{{ path('app_horaires') }}" class="sidebar-link {{ app.request.attributes.get('_route') == 'app_horaires' ? 'active' : '' }}">Horaires &
																																																																								Lieux</a>
					<a href="{{ path('app_history') }}" class="sidebar-link {{ app.request.attributes.get('_route') == 'app_history' ? 'active' : '' }}">Histoire</a>
					<a href="{{ path('app_gallery') }}" class="sidebar-link {{ app.request.attributes.get('_route') == 'app_gallery' ? 'active' : '' }}">Galerie photos</a>
					<a href="{{ path('app_contact') }}" class="sidebar-link {{ app.request.attributes.get('_route') == 'app_contact' ? 'active' : '' }}">Nous
																																																																																																																																																																																																												                    contacter</a>
				</nav>

				<div class="sidebar-footer">
					{% if app.user %}
						<a href="{{ path('admin') }}" class="btn-sidebar">Administration</a>
						<a href="{{ path('app_logout') }}" class="btn-sidebar" style="margin-top: 0.5rem; background: transparent; border: 2px solid rgba(255,255,255,0.3);">
							Déconnexion
						</a>
					{% else %}
						<a href="{{ path('app_login') }}" class="btn-sidebar">Se connecter</a>
					{% endif %}
				</div>
			</aside>

			{# CONTENU PRINCIPAL - Variable selon la page #}
			<main class="main-content"> {% block body %}{% endblock %}

				{# FOOTER - Commun à toutes les pages #}
				<footer class="site-footer">
					<div
						class="site-footer-inner">

						{# Colonne identité #}
						<div class="footer-col footer-brand">
							<div class="footer-brand-head">
								<img src="{{ asset('images/logoarcherie-transparent.png') }}" alt="Logo Archers des Albères" class="footer-logo">
								<span class="footer-brand-name">Archers des Albères</span>
							</div>
							<p class="footer-tagline">Club de tir à l'arc affilié FFTA · Depuis 1991</p>
							<div class="footer-contact">
								<a href="mailto:{{ app.request.attributes.get('settings')['contact_email']|default('archersdesalberes@gmail.com') }}">
									<span class="footer-ico">📧</span>
									{{ app.request.attributes.get('settings')['contact_email']|default('archersdesalberes@gmail.com') }}
								</a>
								<a href="tel:{{ app.request.attributes.get('settings')['contact_phone']|default('06 02 23 72 58')|replace({' ': ''}) }}">
									<span class="footer-ico">📞</span>
									{{ app.request.attributes.get('settings')['contact_phone']|default('06 02 23 72 58') }}
								</a>
								<span class="footer-loc">
									<span class="footer-ico">📍</span>
									Sorède, Pyrénées-Orientales</span>
							</div>
						</div>

						{# Colonne navigation #}
						<div class="footer-col">
							<h4 class="footer-title">Navigation</h4>
							<ul class="footer-list">
								<li>
									<a href="{{ path('app_adhesion') }}">Adhérer au club</a>
								</li>
								<li>
									<a href="{{ path('app_horaires') }}">Horaires & lieux</a>
								</li>
								<li>
									<a href="{{ path('app_actualites') }}">Actualités</a>
								</li>
								<li>
									<a href="{{ path('app_gallery') }}">Galerie photos</a>
								</li>
								<li>
									<a href="{{ path('app_contact') }}">Nous contacter</a>
								</li>
							</ul>
						</div>

						{# Colonne documents + réseaux #}
						<div class="footer-col">
							<h4 class="footer-title">Le club</h4>
							<ul class="footer-list">
								<li>
									<a href="{{ path('app_history') }}">Notre histoire</a>
								</li>
								<li>
									<a href="{{ asset('documents/statuts.pdf') }}" target="_blank" rel="noopener">📄 Statuts de l'association</a>
								</li>
							</ul>
							<div class="footer-social">
								<a href="https://www.facebook.com/Archers.de.sorede/" target="_blank" rel="noopener" class="footer-social-link" aria-label="Facebook">
									<span class="footer-ico">📘</span>
									Facebook
								</a>
							</div>
						</div>

						{# Colonne partenaires #}
						<div class="footer-col">
							<h4 class="footer-title">Nos partenaires</h4>
							<div class="footer-partners">
								{% if partners is defined and partners|length > 0 %}
									{% for partner in partners|slice(0, 4) %}
										<div class="footer-partner-box">
											{% if partner.logo %}
												<img src="{{ asset('uploads/partners/' ~ partner.logo) }}" alt="{{ partner.name }}">
											{% else %}
												<span>🏛️
													{{ partner.name }}</span>
											{% endif %}
										</div>
									{% endfor %}
								{% else %}
									<div class="footer-partner-box">
										<span>🏛️ Mairie</span>
									</div>
									<div class="footer-partner-box">
										<span>🏢 Région</span>
									</div>
									<div class="footer-partner-box">
										<span>🎯 FFTA</span>
									</div>
									<div class="footer-partner-box">
										<span>🏪 Commerces</span>
									</div>
								{% endif %}
							</div>
						</div>

					</div>

					<div class="site-footer-bottom">
						<span>©
							{{ 'now'|date('Y') }}
							Compagnie des Archers des Albères — Tous droits réservés</span>
						{% if not app.user %}
							<a href="{{ path('app_login') }}" class="footer-admin-link">Espace membres</a>
						{% endif %}
					</div>
				</footer>

			</main>

		</div>
	</body>

</html>
