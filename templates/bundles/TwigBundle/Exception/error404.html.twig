{% extends 'base.html.twig' %}

{% block title %}Page introuvable - Compagnie des Archers des Albères
{% endblock %}

{% block body %}
	<section class="hero error-hero">
		<div class="hero-content error-content">
			<div class="error-text">
				<span class="error-code">404</span>
				<h1>Cette
					<span class="gradient-text">cible</span>
					n'existe pas</h1>
				<p>La page que vous cherchez a été déplacée, supprimée, ou n'a jamais existé.
					Reprenez votre visée depuis l'accueil.</p>
				<div class="error-actions">
					<a href="{{ path('app_home') }}" class="btn-error-primary">Retour à l'accueil</a>
					<a href="{{ path('app_contact') }}" class="btn-error-secondary">Nous contacter</a>
				</div>
			</div>
			<div class="error-icon" aria-hidden="true">🎯</div>
		</div>
	</section>
{% endblock %}
