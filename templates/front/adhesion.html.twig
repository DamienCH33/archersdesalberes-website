{% extends 'base.html.twig' %}

{% block title %}Adhésion - Compagnie des Archers des Albères
{% endblock %}

{% block body %}
	{% set mois = 'now'|date('n') %}
	{% set annee = 'now'|date('Y') %}
	{% set saison = mois >= 5 ? annee ~ '-' ~ (annee + 1) : (annee - 1) ~ '-' ~ annee %}

	<section class="hero" style="min-height: 300px; display: flex; align-items: center;">
		<div class="hero-content">
			<div class="hero-text">
				<h1>Adhésion
					<span class="gradient-text">{{ saison }}</span>
				</h1>
				<p>Devenez membre de notre club et pratiquez le tir à l'arc dans une ambiance conviviale.</p>
			</div>
		</div>
	</section>

	<section class="section">
		<div
			class="container" style="max-width: 900px; margin: 0 auto;">

			{# Tarifs #}
			<div class="section-header">
				<h2 class="section-title">Tarifs</h2>
				<p class="section-subtitle">Cotisations annuelles saison
					{{ saison }}</p>
			</div>

			<div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; margin-bottom: 4rem;">
				<div style="background: linear-gradient(135deg, #E8F5E9, #C8E6C9); padding: 2rem; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
					<h3 style="color: #2E7D32; font-size: 1.5rem; margin-bottom: 1rem;">Adultes</h3>
					<div style="font-size: 2rem; font-weight: bold; color: #1B5E20; margin-bottom: 0.5rem;">Licence FFTA : 135€</div>
					<ul style="list-style: none; padding: 0; margin-top: 1.5rem; color: #2E7D32;">
						<li style="padding: 0.5rem 0;">Tarif 2ème membre : 130€</li>
						<li style="padding: 0.5rem 0;">Tarif 3ème membre :125€</li>
					</li>
				</ul>
			</div>

			<div style="background: linear-gradient(135deg, #E3F2FD, #BBDEFB); padding: 2rem; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
				<h3 style="color: #1976D2; font-size: 1.5rem; margin-bottom: 1rem;">Jeunes</h3>
				<div style="font-size: 1.5rem; font-weight: bold; color: #0D47A1; margin-bottom: 0.5rem;">Licence FFTA jeune : 108€</div>
				<p style="color: #1565C0;">(Jusqu’à 19 ans)</p>
				<ul style="list-style: none; padding: 0; margin-top: 1.5rem; color: #1976D2;">
					<li style="padding: 0.5rem 0;">Tarif 2ème membre : 103€</li>
					<li style="padding: 0.5rem 0;">Tarif 3ème membre :98€</li>
				</ul>
			</div>

			<div style="background: linear-gradient(135deg, #FFF3E0, #FFE0B2); padding: 2rem; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
				<h3 style="color: #F57C00; font-size: 1.5rem; margin-bottom: 1rem;">Licence FFTA découverte</h3>
				<p style="color: #EF6C00;">(Avril – Septembre)</p>
				<ul style="list-style: none; padding: 0; margin-top: 1.5rem; color: #F57C00;">
					<li style="padding: 0.5rem 0;">Tarif : 50 €</li>
				</ul>
			</div>

			<div style="background: linear-gradient(135deg, #F3E5F5, #E1BEE7); padding: 2rem; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
				<h3 style="color: #7B1FA2; font-size: 1.5rem; margin-bottom: 1rem;">Matériel</h3>
				<ul style="list-style: none; padding: 0; margin-top: 1.5rem; color: #7B1FA2;">
					<li style="padding: 0.5rem 0;">Location arc club :40€</li>
					<li style="padding: 0.5rem 0;">Caution arc club : 150€</li>
				</ul>
			</div>
		</div>

		{# Documents à fournir #}
		<div class="section-header" style="margin-top: 4rem;">
			<h2 class="section-title">Documents à fournir</h2>
		</div>

		<div style="background: #F5F5F5; padding: 2rem; border-radius: 12px; margin-bottom: 3rem;">
			<ul style="list-style: none; padding: 0; font-size: 1.1rem; line-height: 2;">
				<li style="padding: 0.5rem 0; border-bottom: 1px solid #E0E0E0;">Formulaire d'inscription complété</li>
				<li style="padding: 0.5rem 0; border-bottom: 1px solid #E0E0E0;">Questionnaire de santé rempli et certificat médical si nécessaire</li>
				<li style="padding: 0.5rem 0; border-bottom: 1px solid #E0E0E0;">Règlement intérieur signé
				</li>
				<li style="padding: 0.5rem 0;">Paiement par chèque ou espèces uniquement</li>
			</ul>
		</div>

		{# Avantages #}
		<div class="section-header" style="margin-top: 4rem;">
			<h2 class="section-title">Les avantages de l'adhésion</h2>
		</div>

		<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; margin-bottom: 3rem;">
			<div style="text-align: center; padding: 1.5rem;">
				<div style="font-size: 3rem; margin-bottom: 1rem;">🎯</div>
				<h4 style="color: #2E7D32; margin-bottom: 0.5rem;">Matériel fourni</h4>
				<p style="color: #666;">Arcs, flèches et équipements de protection</p>
			</div>
			<div style="text-align: center; padding: 1.5rem;">
				<div style="font-size: 3rem; margin-bottom: 1rem;">👨‍🏫</div>
				<h4 style="color: #2E7D32; margin-bottom: 0.5rem;">Encadrement qualifié</h4>
				<p style="color: #666;">Encadrants diplômés FFTA</p>
			</div>
			<div style="text-align: center; padding: 1.5rem;">
				<div style="font-size: 3rem; margin-bottom: 1rem;">🏆</div>
				<h4 style="color: #2E7D32; margin-bottom: 0.5rem;">Compétitions</h4>
				<p style="color: #666;">Accès aux tournois départementaux et régionaux</p>
			</div>
			<div style="text-align: center; padding: 1.5rem;">
				<div style="font-size: 3rem; margin-bottom: 1rem;">🎉</div>
				<h4 style="color: #2E7D32; margin-bottom: 0.5rem;">Convivialité</h4>
				<p style="color: #666;">Rejoignez une communauté passionnée</p>
			</div>
			<div style="text-align: center; padding: 1.5rem;">
				<div style="font-size: 3rem; margin-bottom: 1rem;">🏹</div>
				<h4 style="color: #2E7D32; margin-bottom: 0.5rem;">Installations dédiées</h4>
				<p style="color: #666;">Salle d'entraînement et terrain extérieur</p>
			</div>
		</div>
	</div>
</section>{% endblock %}
