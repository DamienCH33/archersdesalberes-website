{% extends 'base.html.twig' %}

{% block title %}Histoire du club - Compagnie des Archers des Albères{% endblock %}

{% block body %}
<section class="hero" style="min-height: 300px; display: flex; align-items: center;">
    <div class="hero-content">
        <div class="hero-text">
            <span class="hero-badge">📜 Notre histoire</span>
            <h1>39 ans de <span class="gradient-text">passion</span></h1>
            <p>Découvrez l'histoire de la Compagnie des Archers des Albères depuis sa création en 1985.</p>
        </div>
    </div>
</section>

<section class="section">
    <div class="container" style="max-width: 900px; margin: 0 auto;">
        
        {# Introduction #}
        <div style="background: linear-gradient(135deg, #E8F5E9, #C8E6C9); padding: 3rem; border-radius: 12px; margin-bottom: 4rem; text-align: center;">
            <div style="font-size: 4rem; margin-bottom: 1rem;">🏹</div>
            <h2 style="color: #1B5E20; font-size: 2rem; margin-bottom: 1rem;">Depuis 1985 à Argelès-sur-Mer</h2>
            <p style="font-size: 1.2rem; color: #2E7D32; line-height: 1.8; max-width: 700px; margin: 0 auto;">
                La Compagnie des Archers des Albères est née de la passion de quelques archers 
                souhaitant partager leur amour du tir à l'arc dans une ambiance conviviale et familiale.
            </p>
        </div>

        {# Timeline #}
        <div class="section-header">
            <h2 class="section-title">Dates clés</h2>
        </div>

        <div style="position: relative; padding-left: 3rem; margin-bottom: 4rem;">
            {# Ligne verticale #}
            <div style="position: absolute; left: 1rem; top: 0; bottom: 0; width: 3px; background: linear-gradient(180deg, #2E7D32, #4CAF50);"></div>

            {# 1985 #}
            <div style="position: relative; margin-bottom: 3rem;">
                <div style="position: absolute; left: -2.5rem; width: 2rem; height: 2rem; background: #2E7D32; border-radius: 50%; border: 4px solid white; box-shadow: 0 0 0 3px #2E7D32;"></div>
                <div style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                    <div style="color: #2E7D32; font-weight: bold; font-size: 1.5rem; margin-bottom: 0.5rem;">1985</div>
                    <h3 style="color: #1B5E20; margin-bottom: 1rem; font-size: 1.3rem;">Création du club</h3>
                    <p style="color: #666; line-height: 1.6;">
                        Fondation de la Compagnie des Archers des Albères par une poignée de passionnés. 
                        Les premiers entraînements se déroulent au stade municipal avec une dizaine d'adhérents.
                    </p>
                </div>
            </div>

            {# 1992 #}
            <div style="position: relative; margin-bottom: 3rem;">
                <div style="position: absolute; left: -2.5rem; width: 2rem; height: 2rem; background: #388E3C; border-radius: 50%; border: 4px solid white; box-shadow: 0 0 0 3px #388E3C;"></div>
                <div style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                    <div style="color: #388E3C; font-weight: bold; font-size: 1.5rem; margin-bottom: 0.5rem;">1992</div>
                    <h3 style="color: #1B5E20; margin-bottom: 1rem; font-size: 1.3rem;">Premier championnat</h3>
                    <p style="color: #666; line-height: 1.6;">
                        Organisation du premier championnat départemental à Argelès-sur-Mer. 
                        Le club compte désormais 35 membres actifs et commence à se faire un nom dans la région.
                    </p>
                </div>
            </div>

            {# 2003 #}
            <div style="position: relative; margin-bottom: 3rem;">
                <div style="position: absolute; left: -2.5rem; width: 2rem; height: 2rem; background: #4CAF50; border-radius: 50%; border: 4px solid white; box-shadow: 0 0 0 3px #4CAF50;"></div>
                <div style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                    <div style="color: #4CAF50; font-weight: bold; font-size: 1.5rem; margin-bottom: 0.5rem;">2003</div>
                    <h3 style="color: #1B5E20; margin-bottom: 1rem; font-size: 1.3rem;">Nouveau terrain</h3>
                    <p style="color: #666; line-height: 1.6;">
                        Inauguration d'un terrain de tir permanent en extérieur. 
                        Cette infrastructure permet au club de diversifier ses activités et d'accueillir davantage d'archers.
                    </p>
                </div>
            </div>

            {# 2015 #}
            <div style="position: relative; margin-bottom: 3rem;">
                <div style="position: absolute; left: -2.5rem; width: 2rem; height: 2rem; background: #66BB6A; border-radius: 50%; border: 4px solid white; box-shadow: 0 0 0 3px #66BB6A;"></div>
                <div style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                    <div style="color: #66BB6A; font-weight: bold; font-size: 1.5rem; margin-bottom: 0.5rem;">2015</div>
                    <h3 style="color: #1B5E20; margin-bottom: 1rem; font-size: 1.3rem;">30 ans du club</h3>
                    <p style="color: #666; line-height: 1.6;">
                        Célébration du 30ème anniversaire avec un grand tournoi amical réunissant plus de 80 archers 
                        venus de toute la région. Le club compte alors près de 100 adhérents.
                    </p>
                </div>
            </div>

            {# 2024 #}
            <div style="position: relative;">
                <div style="position: absolute; left: -2.5rem; width: 2rem; height: 2rem; background: #81C784; border-radius: 50%; border: 4px solid white; box-shadow: 0 0 0 3px #81C784;"></div>
                <div style="background: linear-gradient(135deg, #E8F5E9, #ffffff); padding: 2rem; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); border: 2px solid #2E7D32;">
                    <div style="color: #1B5E20; font-weight: bold; font-size: 1.5rem; margin-bottom: 0.5rem;">2024</div>
                    <h3 style="color: #1B5E20; margin-bottom: 1rem; font-size: 1.3rem;">Aujourd'hui</h3>
                    <p style="color: #666; line-height: 1.6;">
                        Le club compte 127 membres actifs, dispose d'infrastructures modernes et continue de promouvoir 
                        le tir à l'arc auprès de tous les publics avec la même passion qu'au premier jour.
                    </p>
                </div>
            </div>
        </div>

        {# Valeurs #}
        <div class="section-header" style="margin-top: 5rem;">
            <h2 class="section-title">Nos valeurs</h2>
            <p class="section-subtitle">Ce qui nous anime depuis 39 ans</p>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; margin-bottom: 4rem;">
            <div style="text-align: center; padding: 2rem; background: linear-gradient(135deg, #E8F5E9, #ffffff); border-radius: 12px;">
                <div style="font-size: 3rem; margin-bottom: 1rem;">🤝</div>
                <h4 style="color: #2E7D32; margin-bottom: 0.5rem; font-size: 1.3rem;">Convivialité</h4>
                <p style="color: #666; line-height: 1.6;">
                    Une ambiance familiale où chacun trouve sa place, du débutant au compétiteur
                </p>
            </div>

            <div style="text-align: center; padding: 2rem; background: linear-gradient(135deg, #E3F2FD, #ffffff); border-radius: 12px;">
                <div style="font-size: 3rem; margin-bottom: 1rem;">🎯</div>
                <h4 style="color: #1976D2; margin-bottom: 0.5rem; font-size: 1.3rem;">Excellence</h4>
                <p style="color: #666; line-height: 1.6;">
                    Un encadrement qualifié pour progresser et atteindre ses objectifs
                </p>
            </div>

            <div style="text-align: center; padding: 2rem; background: linear-gradient(135deg, #FFF3E0, #ffffff); border-radius: 12px;">
                <div style="font-size: 3rem; margin-bottom: 1rem;">🌍</div>
                <h4 style="color: #F57C00; margin-bottom: 0.5rem; font-size: 1.3rem;">Ouverture</h4>
                <p style="color: #666; line-height: 1.6;">
                    Accessible à tous, sans distinction d'âge, de niveau ou de condition physique
                </p>
            </div>

            <div style="text-align: center; padding: 2rem; background: linear-gradient(135deg, #F3E5F5, #ffffff); border-radius: 12px;">
                <div style="font-size: 3rem; margin-bottom: 1rem;">💚</div>
                <h4 style="color: #7B1FA2; margin-bottom: 0.5rem; font-size: 1.3rem;">Respect</h4>
                <p style="color: #666; line-height: 1.6;">
                    Du matériel, de la nature, des autres archers et des règles de sécurité
                </p>
            </div>
        </div>

        {# Palmarès #}
        <div class="section-header" style="margin-top: 5rem;">
            <h2 class="section-title">Palmarès</h2>
            <p class="section-subtitle">Quelques succès marquants</p>
        </div>

        <div style="background: linear-gradient(135deg, #FFF3E0, #ffffff); padding: 3rem; border-radius: 12px; margin-bottom: 4rem;">
            <div style="display: grid; gap: 1.5rem;">
                <div style="display: flex; align-items: center; gap: 1.5rem; padding: 1rem; background: white; border-radius: 8px;">
                    <div style="font-size: 2.5rem;">🥇</div>
                    <div>
                        <h4 style="color: #F57C00; margin-bottom: 0.3rem;">Champion départemental 2023</h4>
                        <p style="color: #666; margin: 0;">Arc à poulies - Catégorie Senior</p>
                    </div>
                </div>

                <div style="display: flex; align-items: center; gap: 1.5rem; padding: 1rem; background: white; border-radius: 8px;">
                    <div style="font-size: 2.5rem;">🥈</div>
                    <div>
                        <h4 style="color: #F57C00; margin-bottom: 0.3rem;">Vice-champion régional 2022</h4>
                        <p style="color: #666; margin: 0;">Arc classique - Catégorie Junior</p>
                    </div>
                </div>

                <div style="display: flex; align-items: center; gap: 1.5rem; padding: 1rem; background: white; border-radius: 8px;">
                    <div style="font-size: 2.5rem;">🥉</div>
                    <div>
                        <h4 style="color: #F57C00; margin-bottom: 0.3rem;">3ème place Coupe de France 2021</h4>
                        <p style="color: #666; margin: 0;">Équipe mixte</p>
                    </div>
                </div>

                <div style="display: flex; align-items: center; gap: 1.5rem; padding: 1rem; background: white; border-radius: 8px;">
                    <div style="font-size: 2.5rem;">🏆</div>
                    <div>
                        <h4 style="color: #F57C00; margin-bottom: 0.3rem;">Plus de 50 podiums</h4>
                        <p style="color: #666; margin: 0;">Toutes catégories confondues depuis 2015</p>
                    </div>
                </div>
            </div>
        </div>

        {# CTA #}
        <div style="background: linear-gradient(135deg, #2E7D32, #4CAF50); padding: 3rem; border-radius: 12px; text-align: center; color: white;">
            <h3 style="font-size: 2rem; margin-bottom: 1rem;">Écrivez l'histoire avec nous</h3>
            <p style="font-size: 1.2rem; margin-bottom: 2rem; opacity: 0.9;">
                Rejoignez la Compagnie des Archers des Albères et participez à la suite de notre aventure !
            </p>
            <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                <a href="{{ path('app_adhesion') }}" class="btn-primary" style="background: white; color: #2E7D32;">Adhérer</a>
                <a href="{{ path('app_contact') }}" class="btn-secondary" style="border-color: white; color: white;">Nous contacter</a>
            </div>
        </div>

    </div>
</section>
{% endblock %}
