{% extends 'base.html.twig' %}

{% block title %}Horaires & Lieux - Compagnie des Archers des Albères
{% endblock %}

{% block body %}
	{% set mois = 'now'|date('n') %}
	{% set annee = 'now'|date('Y') %}
	{% set saison = mois >= 5 ? annee ~ '-' ~ (annee + 1) : (annee - 1) ~ '-' ~ annee %}

	<section class="hero" style="min-height: 300px; display: flex; align-items: center;">
		<div class="hero-content">
			<div class="hero-text">
				<h1>Horaires &
					<span class="gradient-text">Lieux</span>
				</h1>
				<p>Retrouvez tous les créneaux d'entraînement et l'emplacement de nos terrains.</p>
			</div>
		</div>
	</section>

	<section class="section">
		<div
			class="container" style="max-width: 900px; margin: 0 auto;">

			{# Horaires #}
			<div class="section-header">
				<h2 class="section-title">Horaires d'entraînement</h2>
				<p class="section-subtitle">{{ saison }}</p>
			</div>

			<div
				style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-bottom: 2rem; align-items: start;">

				{# ===== Jeunes débutants — BLEU ===== #}
				<div style="background: #fff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 16px rgba(0,0,0,0.06);">
					<div style="background: linear-gradient(135deg, #E3F2FD, #BBDEFB); padding: 1.25rem; text-align: center;">
						<h3 style="color: #0D47A1; font-size: 1.4rem; margin: 0;">Jeunes débutants</h3>
					</div>
					<div style="padding: 1.25rem; display: grid; gap: 1rem;">
						<div style="border-left: 4px solid #1976D2; background: #F8FBFF; border-radius: 10px; padding: 1rem 1.25rem;">
							<div style="display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.75rem;">
								<span style="font-weight: 700; color: #0D47A1; font-size: 1.1rem;">Mercredi</span>
								<span style="font-weight: 700; color: #0D47A1;">🕒 14h30 – 16h00</span>
							</div>
							<div style="display: flex; flex-direction: column; gap: 0.35rem; color: #555; font-size: 0.95rem;">
								<span>❄️ Hiver — en salle</span>
								<span>☀️ Été — sur le terrain</span>
							</div>
						</div>
					</div>
				</div>

				{# ===== Jeunes confirmés — AMBRE ===== #}
				<div style="background: #fff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 16px rgba(0,0,0,0.06);">
					<div style="background: linear-gradient(135deg, #FFF3E0, #FFE0B2); padding: 1.25rem; text-align: center;">
						<h3 style="color: #E65100; font-size: 1.4rem; margin: 0;">Jeunes confirmés</h3>
					</div>
					<div style="padding: 1.25rem; display: grid; gap: 1rem;">
						<div style="border-left: 4px solid #F57C00; background: #FFFAF3; border-radius: 10px; padding: 1rem 1.25rem;">
							<div style="display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.75rem;">
								<span style="font-weight: 700; color: #E65100; font-size: 1.1rem;">Mercredi</span>
								<span style="font-weight: 700; color: #E65100;">🕒 16h30 – 18h00</span>
							</div>
							<div style="display: flex; flex-direction: column; gap: 0.35rem; color: #555; font-size: 0.95rem;">
								<span>❄️ Hiver — en salle</span>
								<span>☀️ Été — sur le terrain</span>
							</div>
						</div>
					</div>
				</div>

				{# ===== Adultes — VERT ===== #}
				<div style="background: #fff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 16px rgba(0,0,0,0.06);">
					<div style="background: linear-gradient(135deg, #E8F5E9, #C8E6C9); padding: 1.25rem; text-align: center;">
						<h3 style="color: #1B5E20; font-size: 1.4rem; margin: 0;">Adultes</h3>
					</div>
					<div
						style="padding: 1.25rem; display: grid; gap: 1rem;">
						{# Mercredi #}
						<div style="border-left: 4px solid #2E7D32; background: #F5FBF6; border-radius: 10px; padding: 1rem 1.25rem;">
							<div style="display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.75rem;">
								<span style="font-weight: 700; color: #1B5E20; font-size: 1.1rem;">Mercredi</span>
								<span style="font-weight: 700; color: #1B5E20;">🕒 18h30 – 20h00</span>
							</div>
							<div style="display: flex; flex-direction: column; gap: 0.35rem; color: #555; font-size: 0.95rem;">
								<span>❄️ Hiver — en salle</span>
								<span>☀️ Été — sur le terrain</span>
							</div>
						</div>
						{# Vendredi (horaires différents selon la saison) #}
						<div style="border-left: 4px solid #2E7D32; background: #F5FBF6; border-radius: 10px; padding: 1rem 1.25rem;">
							<div style="font-weight: 700; color: #1B5E20; font-size: 1.1rem; margin-bottom: 0.75rem;">Vendredi</div>
							<div style="display: flex; flex-direction: column; gap: 0.5rem; color: #555; font-size: 0.95rem;">
								<div style="display: flex; flex-direction: column; gap: 0.35rem; color: #555; font-size: 0.95rem;">
									<span>❄️ Hiver — salle</span>
									<strong style="color: #1B5E20;">🕒 18h30 – 20h00</strong>
								</div>
								<div style="display: flex; flex-direction: column; gap: 0.35rem; color: #555; font-size: 0.95rem;">
									<span>☀️ Été — terrain</span>
									<strong style="color: #1B5E20;">🕒 17h30 – 19h00</strong>
								</div>
							</div>
						</div>
					</div>
				</div>

			</div>

			{# Section Banyuls-sur-Mer #}

			<div style="
															background: linear-gradient(135deg, #E3F2FD, #F8FBFF);
															border-radius: 12px; padding: 1.25rem 1.5rem; display: flex; align-items: center; justify-content: center; gap: 0.75rem; flex-wrap: wrap; text-align: center; margin-bottom: 4rem;
															">
				<span style="font-weight: 700; color: #0D47A1;">📍 Section Banyuls-sur-Mer</span>
				<span style="color: #0D47A1;">Jeudi · 🕒 21h00 – 23h00 · en salle</span>
			</div>

			{# Localisation #}
			<div class="section-header" style="margin-top: 4rem;">
				<h2 class="section-title">LIEUX D’ENTRAINEMENTS</h2>
			</div>

			{# Salle d'entraînement avec sa carte #}
			<div style="background: #F5F5F5; padding: 2rem; border-radius: 12px; margin-bottom: 2rem;">
				<h3 style="color: #2E7D32; margin-bottom: 1rem; font-size: 1.5rem;">SALLE SAINT-GENIS DES FONTAINES</h3>
				<p style="font-size: 1.2rem; color: #333; margin-bottom: 1rem;">
					<strong>Salle polyvalente 1er étage :</strong><br>
					Place Jean Rolland<br>
					66740 Saint-Genis Des Fontaines
				</p>
				<p style="color: #666; margin-bottom: 1.5rem;">
					🚗 Parking gratuit disponible<br>
				</p>
				<div style="border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
					<iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1148.274940717713!2d2.9217390348348142!3d42.54292503904275!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x12b07797575b280f%3A0x5c681d0436fb9ede!2sCompagnie%20des%20Archers%20des%20Alb%C3%A8res!5e1!3m2!1sfr!2sfr!4v1781614838545!5m2!1sfr!2sfr" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
				</div>
			</div>

			{# Terrain extérieur avec sa carte #}
			<div style="background: #F5F5F5; padding: 2rem; border-radius: 12px; margin-bottom: 3rem;">
				<h3 style="color: #1976D2; margin-bottom: 1rem; font-size: 1.5rem;">TERRAIN EXTERIEUR SOREDE</h3>
				<p style="font-size: 1.2rem; color: #333; margin-bottom: 1rem;">
					<strong>Pas de tir André Llong :</strong><br>
					Rue du passage à gué
					<br>(face aux pépinières mairie de Sorède)
					<br>66690 Sorède
				</p>
				<p style="color: #666; margin-bottom: 1.5rem;">
					🚗 Parking gratuit<br>
					🌲 En pleine nature<br>
					♿ Accès PMR
				</p>
				<div style="border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
					<iframe src="https://www.google.com/maps/embed?pb=!1m17!1m12!1m3!1d676.8936836851399!2d2.961361068250648!3d42.538570641903405!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zNDLCsDMyJzE5LjgiTiAywrA1Nyc0Mi42IkU!5e0!3m2!1sfr!2sfr!4v1781532741413!5m2!1sfr!2sfr" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
				</div>
			</div>

			{# Salle BANYULS/MER #}
			<div style="background: #F5F5F5; padding: 2rem; border-radius: 12px; margin-bottom: 2rem;">
				<h3 style="color: #2E7D32; margin-bottom: 1rem; font-size: 1.5rem;">SALLE BANYULS/MER</h3>
				<p style="font-size: 1.2rem; color: #333; margin-bottom: 1rem;">
					<strong>Salle Bartissol :</strong><br>
					19 rue des angles<br>
					66700 Banyuls-sur-Mer
				</p>
				<div style="border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
					<iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5885.012877374496!2d3.121824112854808!3d42.480784827343854!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x12ba7fbb2e4f45b7%3A0x6646268c45004ca2!2sSalle%20Polyvalente%20Bartissol!5e0!3m2!1sfr!2sfr!4v1781531797985!5m2!1sfr!2sfr" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
				</div>
			</div>
		</div>
	</section>
{% endblock %}
