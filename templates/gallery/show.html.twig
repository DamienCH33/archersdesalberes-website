{% extends 'base.html.twig' %}

{% block title %}
	{{ album.title }}
	- Galerie - Compagnie des Archers des Albères
{% endblock %}

{% block body %}
	<section class="hero" style="min-height: 280px; display: flex; align-items: center;">
		<div class="hero-content">
			<div class="hero-text">
				<a href="{{ path('app_gallery') }}" style="color: #2E7D32; text-decoration: none; font-weight: 600; display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem;">
					Retour à la galerie
				</a>
				<span class="hero-badge">📸 Album photo</span>
				<h1>
					<span class="gradient-text">{{ album.title }}</span>
				</h1>
				<p>
					📷
					{{ album.photos|length }}
					photo{{ album.photos|length > 1 ? 's' : '' }}
					· 📅
					{{ album.createdAt|date('d/m/Y') }}
				</p>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container" style="max-width: 1200px; margin: 0 auto;">

			{% if album.photos|length > 0 %}
				<div class="photo-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem;">

					{% for photo in album.photos %}
						<div class="photo-item" data-photo-index="{{ loop.index0 }}" data-photo-src="{{ asset('uploads/photos/' ~ photo.path) }}" data-photo-caption="{{ photo.caption ?? '' }}" style="position: relative; aspect-ratio: 1; border-radius: 10px; overflow: hidden; cursor: pointer; background: #f0f0f0; box-shadow: 0 2px 8px rgba(0,0,0,0.08); transition: all 0.3s;">

							<img src="{{ asset('uploads/photos/' ~ photo.path) }}" alt="{{ photo.caption ?? photo.filename }}" loading="lazy" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s;">

							<div class="photo-overlay" style="position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 50%, rgba(0,0,0,0.7)); opacity: 0; transition: opacity 0.3s; display: flex; align-items: flex-end; padding: 1rem;">
								{% if photo.caption %}
									<p style="color: white; font-size: 0.9rem; line-height: 1.4; margin: 0;">
										{{ photo.caption }}
									</p>
								{% else %}
									<span style="color: white; font-size: 0.9rem; font-weight: 600;">
										🔍 Voir en grand
									</span>
								{% endif %}
							</div>
						</div>
					{% endfor %}

				</div>

			{% else %}
				<div style="text-align: center; padding: 5rem 2rem; background: #F5F5F5; border-radius: 12px;">
					<div style="font-size: 5rem; margin-bottom: 1rem;">📭</div>
					<h3 style="color: #666;">Aucune photo dans cet album</h3>
				</div>
			{% endif %}

		</div>
	</section>

	{# LIGHTBOX #}
	<div id="lightbox" class="lightbox" style="display: none;">
		<button class="lightbox-close" aria-label="Fermer">
			<svg viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
				<line x1="18" y1="6" x2="6" y2="18"></line>
				<line x1="6" y1="6" x2="18" y2="18"></line>
			</svg>
		</button>

		<button class="lightbox-btn lightbox-prev" aria-label="Photo précédente">
			<svg viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
				<polyline points="15 18 9 12 15 6"></polyline>
			</svg>
		</button>

		<button class="lightbox-btn lightbox-next" aria-label="Photo suivante">
			<svg viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
				<polyline points="9 18 15 12 9 6"></polyline>
			</svg>
		</button>

		<div class="lightbox-content">
			<img id="lightbox-img" src="" alt="">
			<div id="lightbox-caption" class="lightbox-caption"></div>
			<div id="lightbox-counter" class="lightbox-counter"></div>
		</div>
	</div>
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script src="{{ asset('js/lightbox.js') }}" defer></script>
{% endblock %}
