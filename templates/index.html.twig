{% extends 'base.html.twig' %}

{% block title %}Accueil - Compagnie des Archers des Albères
{% endblock %}

{% block body %}
	{# HERO SECTION #}
	<section class="hero">
		<div class="hero-content">
			<div class="hero-text">
				<h1>Compagnie des
					<span class="gradient-text">Archers des Albères</span>
				</h1>
				<p>Un club convivial et professionnel au pied des Pyrénées.<br>
					Du débutant au compétiteur, tous les niveaux sont les bienvenus.</p>
			</div>
			<div class="hero-logo">
				<img src="{{ asset('images/logoarcherie-transparent.png') }}" alt="Compagnie des Archers des Albères">
			</div>
		</div>
	</section>

	{# SLIDER MODERNE #}
	<section class="section" style="padding: 0; margin-bottom: 4rem;">
		<div class="modern-slider" style="max-width: 1100px; margin: 0 auto;">
			<div class="slider-wrapper">
				<div class="slider-track">
					{% for photo in sliderPhotos %}
						<div class="slide">
							<img src="{{ asset('uploads/photos/' ~ photo.path) }}" alt="{{ photo.caption ?? 'Photo du club' }}" loading="lazy">

							<div class="slide-overlay">
								<div class="slide-caption">
									<span class="slide-badge">
										📸
										{{ photo.album.title }}
									</span>
								</div>
							</div>
						</div>
					{% endfor %}
				</div>

				{# Boutons nav #}
				<button class="slider-btn prev" aria-label="Photo précédente">
					<svg viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
						<polyline points="15 18 9 12 15 6"></polyline>
					</svg>
				</button>
				<button class="slider-btn next" aria-label="Photo suivante">
					<svg viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
						<polyline points="9 18 15 12 9 6"></polyline>
					</svg>
				</button>

				{# Compteur #}
				<div class="slider-counter">
					<span class="counter-current">1</span>
					/
					<span class="counter-total">5</span>
				</div>

				{# Dots #}
				<div class="slider-dots"></div>

				{# Barre de progression #}
				<div class="slider-progress">
					<div class="slider-progress-bar"></div>
				</div>
			</div>
		</div>
	</section>

	<div
		class="content-wrap">
		{# Présentation #}
		<div style="background: linear-gradient(135deg, #E8F5E9, #C8E6C9); padding: 3rem; border-radius: 0; margin-bottom: 4rem;">
			<h2 style="color: #1B5E20; font-size: 2rem; margin-bottom: 1.5rem; text-align: center;">
				Bienvenue
			</h2>
			<p style="font-size: 1.2rem; color: #2E7D32; line-height: 1.8; text-align: center; margin-bottom: 1.5rem;">
				La Compagnie des Archers des Albères est un club de tir à l'arc affilié à la
												Fédération Française de Tir à l'Arc (FFTA), situé à Sorède dans les Pyrénées-Orientales.
			</p>
			<p style="font-size: 1.1rem; color: #2E7D32; line-height: 1.8; text-align: center;">
				Depuis 1991, nous partageons notre passion du tir à l'arc dans une ambiance conviviale
												et familiale, accueillant archers débutants et confirmés de tous âges.
			</p>
		</div>

		{# Disciplines #}
		<div class="section-header" style="margin: 0 0 1.5rem;">
			<h2 class="section-title">Disciplines pratiquées</h2>
		</div>

		<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem; margin-bottom: 4rem;">
			<div style="background: linear-gradient(135deg, #E8F5E9, #ffffff); padding: 2rem; border-radius: 12px; text-align: center;">
				<div style="font-size: 2.5rem; margin-bottom: 1rem;">🏹</div>
				<h4 style="color: #2E7D32; margin-bottom: 0.5rem; font-size: 1.2rem;">Arc Classique</h4>
				<p style="color: #666; font-size: 0.95rem;">L'arc olympique traditionnel</p>
			</div>

			<div style="background: linear-gradient(135deg, #E3F2FD, #ffffff); padding: 2rem; border-radius: 12px; text-align: center;">
				<div style="font-size: 2.5rem; margin-bottom: 1rem;">⚙️</div>
				<h4 style="color: #1976D2; margin-bottom: 0.5rem; font-size: 1.2rem;">Arc à Poulies</h4>
				<p style="color: #666; font-size: 0.95rem;">Technologie et précision</p>
			</div>

			<div style="background: linear-gradient(135deg, #FFF3E0, #ffffff); padding: 2rem; border-radius: 12px; text-align: center;">
				<div style="font-size: 2.5rem; margin-bottom: 1rem;">🪵</div>
				<h4 style="color: #F57C00; margin-bottom: 0.5rem; font-size: 1.2rem;">Arc Nu</h4>
				<p style="color: #666; font-size: 0.95rem;">Simplicité et instinct</p>
			</div>
		</div>

		{# Activités - GRILLE 2x2 #}
		<div class="section-header" style="margin: 0 0 1.5rem;">
			<h2 class="section-title">Nos activités</h2>
		</div>

		<div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; margin-bottom: 4rem;">

			<div style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); border-left: 4px solid #2E7D32; display: flex; flex-direction: column;">
				<div style="font-size: 3rem; margin-bottom: 1rem;">🎯</div>
				<h3 style="color: #2E7D32; margin-bottom: 1rem; font-size: 1.4rem;">Entraînements réguliers</h3>
				<p style="color: #666; line-height: 1.6; margin-bottom: 1rem; flex: 1;">
					Deux créneaux hebdomadaires pour les adultes pour progresser à votre rythme,
															encadrés par un encadrant club (anciennement encadrant fédéral). Un créneau
															hebdomadaire pour les jeunes débutants et un créneau pour les jeunes confirmés.
															Débutants et confirmés s'entraînent dans une ambiance conviviale.
				</p>
			</div>

			<div style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); border-left: 4px solid #1976D2; display: flex; flex-direction: column;">
				<div style="font-size: 3rem; margin-bottom: 1rem;">🏆</div>
				<h3 style="color: #1976D2; margin-bottom: 1rem; font-size: 1.4rem;">Compétitions</h3>
				<p style="color: #666; line-height: 1.6; margin-bottom: 1rem; flex: 1;">
					Participez aux championnats départementaux, régionaux et nationaux organisés par la FFTA.
															Le club organise également ses propres tournois amicaux tout au long de l'année.
				</p>
			</div>

			<div style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); border-left: 4px solid #F57C00; display: flex; flex-direction: column;">
				<div style="font-size: 3rem; margin-bottom: 1rem;">👥</div>
				<h3 style="color: #F57C00; margin-bottom: 1rem; font-size: 1.4rem;">Initiation et découverte</h3>
				<p style="color: #666; line-height: 1.6; margin-bottom: 1rem; flex: 1;">
					En début de saison, séances d'initiation gratuites pour découvrir le tir à l'arc.
															Tout le matériel est fourni, venez simplement avec votre bonne humeur !
				</p>
			</div>

			<div style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); border-left: 4px solid #7B1FA2; display: flex; flex-direction: column;">
				<div style="font-size: 3rem; margin-bottom: 1rem;">🎉</div>
				<h3 style="color: #7B1FA2; margin-bottom: 1rem; font-size: 1.4rem;">Événements conviviaux</h3>
				<p style="color: #666; line-height: 1.6; flex: 1;">
					Noël, galette des rois, carnaval, tir du roi… Le club organise régulièrement
															des moments de partage pour renforcer les liens entre archers.
				</p>
			</div>

		</div>

		{# Infrastructures #}
		<div class="section-header" style="margin: 0 0 1.5rem;">
			<h2 class="section-title">Nos installations</h2>
		</div>

		<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 4rem;">
			<div style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
				<h4 style="color: #2E7D32; margin-bottom: 1rem; font-size: 1.3rem;">🏛️ Salle couverte</h4>
				<ul style="list-style: none; padding: 0; color: #666; line-height: 2;">
					<li>✓ Tir en intérieur jusqu'à 18m</li>
				</ul>
			</div>

			<div style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
				<h4 style="color: #2E7D32; margin-bottom: 1rem; font-size: 1.3rem;">🌲 Terrain extérieur</h4>
				<ul style="list-style: none; padding: 0; color: #666; line-height: 2;">
					<li>✓ Distances jusqu'à 70m</li>
					<li>✓ Pas de tir couvert</li>
				</ul>
			</div>
		</div>

		{# Matériel #}
		<div style="background: #F5F5F5; padding: 3rem; border-radius: 12px; margin-bottom: 4rem; text-align: center;">
			<div style="font-size: 3rem; margin-bottom: 1rem;">🎯</div>
			<h3 style="color: #2E7D32; margin-bottom: 1rem; font-size: 1.8rem;">Matériel fourni</h3>
			<p style="color: #666; line-height: 1.8; max-width: 600px; margin: 0 auto;">
				Le club met à disposition de ses adhérents tout le matériel nécessaire :
												arcs de différentes puissances, flèches, carquois, protections (plastron, palette, bracelet).
												Vous pouvez également utiliser votre propre matériel.
			</p>
		</div>
	</div>
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script src="{{ asset('js/slider.js') }}" defer></script>
{% endblock %}
