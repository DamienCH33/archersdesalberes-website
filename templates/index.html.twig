{% extends 'base.html.twig' %}

{% block title %}Accueil - Compagnie des Archers des Albères
{% endblock %}

{% block body %}
	{# HERO SECTION #}
	<section class="hero">
		<div class="hero-content">
			<div class="hero-text">
				<span class="hero-badge">🏹 Argelès-sur-Mer · Depuis 1985</span>
				<h1>Compagnie des
					<span class="gradient-text">Archers des Albères</span>
				</h1>
				<p>Un club convivial et professionnel au pied des Pyrénées.<br>
					Du débutant au compétiteur, tous les niveaux sont les bienvenus.</p>
				<div class="hero-cta">
					<a href="{{ path('app_club') }}" class="btn-primary">Découvrir le club</a>
					<a href="{{ path('app_contact') }}" class="btn-secondary">Essai gratuit</a>
				</div>
			</div>
			<div class="hero-logo">
				<img src="{{ asset('images/logoarcherie-transparent.png') }}" alt="Compagnie des Archers des Albères">
			</div>
		</div>
	</section>

	{# STATS SECTION #}
	<section class="stats">
		<div class="container">
			<div class="section-header">
				<h2 class="section-title">Le club en chiffres</h2>
				<p class="section-subtitle">Une communauté passionnée et dynamique</p>
			</div>
			<div class="stats-grid">
				<div class="stat-card">
					<div class="stat-number">{{ stats.membres }}</div>
					<div class="stat-label">Membres actifs</div>
				</div>
				<div class="stat-card">
					<div class="stat-number">{{ stats.annees }}</div>
					<div class="stat-label">Années d'existence</div>
				</div>
				<div class="stat-card">
					<div class="stat-number">{{ stats.competitions }}</div>
					<div class="stat-label">Compétitions par an</div>
				</div>
				<div class="stat-card">
					<div class="stat-number">{{ stats.podiums }}</div>
					<div class="stat-label">Podiums cette année</div>
				</div>
			</div>
		</div>
	</section>

	{# SLIDER MODERNE #}
	<section class="section" style="padding-top: 0;">
		<div class="modern-slider" style="max-width: 1100px; margin: 0 auto;">
			<div class="slider-wrapper">
				<div class="slider-track">
					{% for photo in sliderPhotos %}
						<div class="slide">
							<img src="{{ asset('uploads/photos/' ~ photo.path) }}" alt="{{ photo.caption ?? 'Photo du club' }}" loading="lazy">

							<div class="slide-overlay">
								<div class="slide-caption">
									<span class="slide-badge">
										📸
										{{ photo.album.title }}
									</span>
								</div>
							</div>
						</div>
					{% endfor %}
				</div>

				{# Boutons nav #}
				<button class="slider-btn prev" aria-label="Photo précédente">
					<svg viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
						<polyline points="15 18 9 12 15 6"></polyline>
					</svg>
				</button>
				<button class="slider-btn next" aria-label="Photo suivante">
					<svg viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
						<polyline points="9 18 15 12 9 6"></polyline>
					</svg>
				</button>

				{# Compteur #}
				<div class="slider-counter">
					<span class="counter-current">1</span>
					/
					<span class="counter-total">5</span>
				</div>

				{# Dots #}
				<div class="slider-dots"></div>

				{# Barre de progression #}
				<div class="slider-progress">
					<div class="slider-progress-bar"></div>
				</div>
			</div>
		</div>
	</section>

	{# ÉQUIPE #}
	{% if equipe is defined and equipe|length > 0 %}
		<section class="section">
			<div class="section-header">
				<h2 class="section-title">L'Équipe</h2>
				<p class="section-subtitle">Les personnes qui font vivre le club</p>
			</div>
			<div class="equipe-grid">
				{% for membre in equipe %}
					<div class="equipe-card">
						<div class="equipe-avatar">
							{% if membre.avatar %}
								<img src="{{ asset('uploads/team/' ~ membre.avatar) }}" alt="{{ membre.fullName }}">
							{% endif %}
						</div>
						<div>
							<div class="equipe-name">{{ membre.fullName }}</div>
							<div class="equipe-role">{{ membre.role }}</div>
						</div>
					</div>
				{% endfor %}
			</div>
		</section>
	{% endif %}

	{# GALERIE #}
	{% if galerie is defined and galerie|length > 0 %}
		<section class="galerie">
			<div class="section-header">
				<h2 class="section-title">Galerie</h2>
				<p class="section-subtitle">Le club en images</p>
			</div>
			<div class="galerie-grid">
				{% for album in galerie %}
					<a href="{{ path('gallery_album', {slug: album.slug}) }}" class="galerie-item">
						<div class="galerie-img">
							{% if album.coverImage %}
								<img src="{{ asset('uploads/albums/' ~ album.coverImage) }}" alt="{{ album.title }}" style="width: 100%; height: 100%; object-fit: cover;">
							{% endif %}
						</div>
					</a>
				{% endfor %}
			</div>
		</section>
	{% endif %}

	{# ACTUALITÉS #}
	{% if actualites is defined and actualites|length > 0 %}
		<section class="actualites">
			<div class="section-header">
				<h2 class="section-title">Actualités</h2>
				<p class="section-subtitle">Dernières nouvelles</p>
			</div>
			<div
				class="actu-grid">
				{# Colonne 1 #}
				<div class="actu-column">
					{% for actualite in actualites|slice(0, 3) %}
						<div class="actu-item">
							<div class="actu-date">
								<div class="actu-day">{{ actualite.publishedAt|date('d') }}</div>
								<div class="actu-month">{{ actualite.publishedAt|date('M') }}</div>
							</div>
							<div class="actu-content">
								<span class="actu-category">{{ actualite.category|upper }}</span>
								<h3 class="actu-title">{{ actualite.title }}</h3>
								<p class="actu-text">{{ actualite.content|striptags|slice(0, 80) }}...</p>
								<a href="{{ path('app_article_show', {slug: actualite.slug}) }}" class="actu-link">
									Lire la suite →
								</a>
							</div>
						</div>
					{% endfor %}
				</div>

				{# Colonne 2 #}
				<div class="actu-column">
					{% for actualite in actualites|slice(3, 3) %}
						<div class="actu-item">
							<div class="actu-date">
								<div class="actu-day">{{ actualite.publishedAt|date('d') }}</div>
								<div class="actu-month">{{ actualite.publishedAt|date('M') }}</div>
							</div>
							<div class="actu-content">
								<span class="actu-category">{{ actualite.category|upper }}</span>
								<h3 class="actu-title">{{ actualite.title }}</h3>
								<p class="actu-text">{{ actualite.content|striptags|slice(0, 80) }}...</p>
								<a href="{{ path('app_article_show', {slug: actualite.slug}) }}" class="actu-link">
									Lire la suite →
								</a>
							</div>
						</div>
					{% endfor %}
				</div>
			</div>

			<div class="actu-see-all" style="text-align: center; margin-top: 3rem;">
				<a href="{{ path('app_actualites') }}" class="btn-primary">
					Voir toutes les actualités
				</a>
			</div>
		</section>
	{% endif %}

	{# CTA FINAL #}
	<section class="cta-final">
		<h2>Prêt à tirer vos premières flèches ?</h2>
		<p>
			Venez découvrir le tir à l'arc lors d'une séance d'initiation gratuite. 											      Tout le matériel est fourni, il ne vous reste qu'à venir.
		</p>
		<div class="cta-final-buttons">
			<a href="{{ path('app_contact') }}" class="btn-primary">Prendre contact</a>
			<a href="{{ path('app_adhesion') }}" class="btn-secondary">Voir les tarifs</a>
		</div>
	</section>
{% endblock %}

{# JAVASCRIPT DU SLIDER #}
{% block javascripts %}
	{{ parent() }}
	<script>
		document.addEventListener('DOMContentLoaded', function () {
const sliderTrack = document.querySelector('.slider-track');
if (! sliderTrack) 
return;



const slides = document.querySelectorAll('.slide');
const totalSlides = slides.length;
const dotsContainer = document.querySelector('.slider-dots');
const progressBar = document.querySelector('.slider-progress-bar');
const counterCurrent = document.querySelector('.counter-current');
const sliderWrapper = document.querySelector('.slider-wrapper');
const prevBtn = document.querySelector('.slider-btn.prev');
const nextBtn = document.querySelector('.slider-btn.next');

if (totalSlides === 0) 
return;



let currentSlide = 0;
let autoSlideInterval = null;
const AUTO_SLIDE_DURATION = 5000;

// Création des dots
for (let i = 0; i < totalSlides; i++) {
const dot = document.createElement('button');
dot.className = 'dot';
dot.setAttribute('aria-label', `Aller à la photo ${
i + 1
}`);
dot.addEventListener('click', () => {
goToSlide(i);
restartAutoSlide();
});
dotsContainer.appendChild(dot);
}

const dots = document.querySelectorAll('.dot');

function showSlide(n) {
currentSlide = (n + totalSlides) % totalSlides;
sliderTrack.style.transform = `translateX(${ - currentSlide * 100
}%)`;

// Mise à jour des dots
dots.forEach((dot, index) => {
dot.classList.toggle('active', index === currentSlide);
});

// Mise à jour du compteur
if (counterCurrent) 
counterCurrent.textContent = currentSlide + 1;



// Animation de la slide active
slides.forEach((slide, index) => {
slide.classList.toggle('active', index === currentSlide);
});

// Reset de la barre de progression
resetProgressBar();
}

function moveSlide(direction) {
showSlide(currentSlide + direction);
}

function goToSlide(n) {
showSlide(n);
}

function resetProgressBar() {
if (! progressBar) 
return;



progressBar.style.transition = 'none';
progressBar.style.width = '0%';
// Force un reflow
void progressBar.offsetWidth;
progressBar.style.transition = `width ${AUTO_SLIDE_DURATION}ms linear`;
progressBar.style.width = '100%';
}

function startAutoSlide() {
autoSlideInterval = setInterval(() => moveSlide(1), AUTO_SLIDE_DURATION);
resetProgressBar();
}

function stopAutoSlide() {
clearInterval(autoSlideInterval);
if (progressBar) {
progressBar.style.transition = 'none';
progressBar.style.width = progressBar.offsetWidth + 'px';
}
}

function restartAutoSlide() {
stopAutoSlide();
startAutoSlide();
}

// Boutons précédent / suivant
if (prevBtn) 
prevBtn.addEventListener('click', () => {
moveSlide(-1);
restartAutoSlide();
});



if (nextBtn) 
nextBtn.addEventListener('click', () => {
moveSlide(1);
restartAutoSlide();
});



// Pause au survol
if (sliderWrapper) {
sliderWrapper.addEventListener('mouseenter', stopAutoSlide);
sliderWrapper.addEventListener('mouseleave', startAutoSlide);
}

// Navigation clavier
document.addEventListener('keydown', (e) => {
if (e.key === 'ArrowLeft') {
moveSlide(-1);
restartAutoSlide();
}
if (e.key === 'ArrowRight') {
moveSlide(1);
restartAutoSlide();
}
});

// Support du swipe tactile
let touchStartX = 0;
let touchEndX = 0;
const SWIPE_THRESHOLD = 50;

sliderWrapper.addEventListener('touchstart', (e) => {
touchStartX = e.changedTouches[0].screenX;
}, {passive: true});

sliderWrapper.addEventListener('touchend', (e) => {
touchEndX = e.changedTouches[0].screenX;
const diff = touchStartX - touchEndX;
if (Math.abs(diff) > SWIPE_THRESHOLD) {
moveSlide(diff > 0 ? 1 : -1);
restartAutoSlide();
}
}, {passive: true});

// Init
showSlide(0);
startAutoSlide();
});
	</script>
{% endblock %}
