{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié - Archers des Albères
{% endblock %}

{% block body_class %}login-page
{% endblock %}

{% block body %}
	<div class="login-wrapper">
		<div style="width: 100%; max-width: 460px;">
			<div class="login-card">

				<div class="login-header">
					<div class="login-logo">
						<img src="{{ asset('images/logoarcherie-transparent.png') }}" alt="Logo Archers des Albères">
					</div>
					<span class="login-badge">🔑 Réinitialisation</span>
					<h1 class="login-title">Mot de passe oublié</h1>
					<p class="login-subtitle">Nous vous enverrons un lien de réinitialisation</p>
				</div>

				{% for flash_error in app.flashes('reset_password_error') %}
					<div class="login-alert login-alert-error">
						<span class="login-alert-icon">⚠️</span>
						<span>{{ flash_error }}</span>
					</div>
				{% endfor %}

				{{ form_start(requestForm) }}
				<div class="form-row">
					{{ form_label(requestForm.email, 'Adresse email') }}
					<div class="input-wrapper">
						{{ form_widget(requestForm.email, {
							'attr': {
								'autocomplete': 'email',
								'autofocus': true,
								'placeholder': 'votre@email.com'
							}
						}) }}
					</div>
					{{ form_errors(requestForm.email) }}
					<small style="display:block; margin-top:0.5rem; color:#666;">
						Saisissez votre adresse email : si un compte y est associé,
						vous recevrez un lien de réinitialisation.
					</small>
				</div>

				<button type="submit" class="login-submit">Envoyer le lien</button>
				{{ form_end(requestForm) }}

				<div class="login-divider">
					<span>ou</span>
				</div>

				<a href="{{ path('app_login') }}" class="back-link">Retour à la connexion</a>
			</div>
		</div>
	</div>
{% endblock %}
