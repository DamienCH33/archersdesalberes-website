{% extends 'base.html.twig' %}

{% block title %}Connexion - Administration - Archers des Albères
{% endblock %}

{% block body_class %}login-page
{% endblock %}

{% block body %}
	<div class="login-wrapper">
		<div style="width: 100%; max-width: 460px;">

			<div
				class="login-card">

				{# Header #}
				<div class="login-header">
					<div class="login-logo">
						<img src="{{ asset('images/logoarcherie-transparent.png') }}" alt="Logo Archers des Albères">
					</div>
					<span class="login-badge">🔐 Espace sécurisé</span>
					<h1 class="login-title">Administration</h1>
					<p class="login-subtitle">Réservé aux membres du bureau</p>
				</div>

				{# Alerte erreur #}
				{% if error %}
					<div class="login-alert login-alert-error">
						<span class="login-alert-icon">⚠️</span>
						<span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
					</div>
				{% endif %}

				{# Alerte déjà connecté #}
				{% if app.user %}
					<div class="login-alert login-alert-success">
						<span class="login-alert-icon">✓</span>
						<span>Connecté en tant que
							<strong>{{ app.user.userIdentifier }}</strong>
						</span>
					</div>
				{% endif %}

				{# Formulaire #}
				{{ form_start(loginForm, {'attr': {'novalidate': 'novalidate'}}) }}

				<div class="form-row">
					{{ form_label(loginForm.email, 'Adresse email') }}
					<div class="input-wrapper">
						{{ form_widget(loginForm.email, {
							'attr': {
								'autocomplete': 'email',
								'autofocus': true,
								'placeholder': 'votre@email.com'
							}
						}) }}
					</div>
					{{ form_errors(loginForm.email) }}
				</div>

				<div class="form-row">
					{{ form_label(loginForm.password, 'Mot de passe') }}
					<div class="input-wrapper">
						{{ form_widget(loginForm.password, {
							'attr': {
								'autocomplete': 'current-password',
								'placeholder': '••••••••'
							}
						}) }}
					</div>
					{{ form_errors(loginForm.password) }}
				</div>

				<div class="form-meta">
					<label class="remember-me">
						{{ form_widget(loginForm.remember_me) }}
						<span>Se souvenir de moi</span>
					</label>
					<a href="#" class="forgot-link">Mot de passe oublié ?</a>
				</div>

				{# Bouton submit #}
				{{ form_widget(loginForm.submit, {
					'label': 'Se connecter',
					'attr': {'class': 'login-submit'}
				}) }}

				{{ form_end(loginForm) }}

				{# Séparateur #}
				<div class="login-divider">
					<span>ou</span>
				</div>

				{# Retour site #}
				<a href="{{ path('app_home') }}" class="back-link">
					Retour au site
				</a>
			</div>

			<div class="login-footer">
				©
				{{ 'now'|date('Y') }}
				·
				<a href="{{ path('app_home') }}">Archers des Albères</a>
			</div>

		</div>
	</div>
{% endblock %}
